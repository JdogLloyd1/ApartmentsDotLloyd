#
# Alewife backend — environment configuration template
#
# Copy this file to `.env` in the same directory and fill in the values.
# Never commit the real `.env` file. See App V1 Dynamic/README.md for the
# full setup walkthrough.
#

# Runtime environment: local | staging | production
ENVIRONMENT=local

# SQLAlchemy DB URL. SQLite is the default for local development.
DATABASE_URL=sqlite:///alewife.db

# OpenRouteService API key. Free tier at https://openrouteservice.org/dev/#/signup
# Required by Sprint 4 onward (travel-time matrix, isochrones).
ORS_API_KEY=

# Shared secret required to call POST /api/refresh.
# Generate in PowerShell:
#   $b=New-Object byte[] 32;[System.Security.Cryptography.RandomNumberGenerator]::Create().GetBytes($b);[Convert]::ToBase64String($b)-replace'[+/=]'
REFRESH_BEARER_TOKEN=change-me

# Optional — not used in v1. Reserved for future live Red Line headways.
# Grab one at https://api-v3.mbta.com/portal
MBTA_API_KEY=
